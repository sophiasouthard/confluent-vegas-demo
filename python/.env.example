# Vegas Gaming Demo — Python Producer Environment
# Copy this file to .env and fill in your values.
# After running `terraform apply` in vegas/terraform/, these values are
# auto-written to this file — you do not need to fill them in manually.
#
# Target: Confluent Cloud Basic cluster (provisioned by vegas/terraform/)

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=YOUR_CLUSTER.us-east-1.aws.confluent.cloud:9092
KAFKA_API_KEY=YOUR_KAFKA_API_KEY
KAFKA_API_SECRET=YOUR_KAFKA_API_SECRET

# ── Schema Registry ────────────────────────────────────────────────────────────
SCHEMA_REGISTRY_URL=https://YOUR_SR_ID.us-east-1.aws.confluent.cloud
SCHEMA_REGISTRY_API_KEY=YOUR_SR_API_KEY
SCHEMA_REGISTRY_API_SECRET=YOUR_SR_API_SECRET
